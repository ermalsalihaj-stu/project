{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "findings_requirements.schema.json",
  "title": "UX & Requirements Findings",
  "description": "Output of Agent E - journeys, requirements, edge cases, and backlog candidates",
  "type": "object",
  "required": ["bundle_id", "generated_at", "journeys", "requirements", "edge_cases", "backlog"],
  "properties": {
    "bundle_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },

    "journeys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "steps"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["happy_path", "edge_path", "fallback", "other"] },
          "persona": { "type": "string" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["order", "actor", "action"],
              "properties": {
                "order": { "type": "integer", "minimum": 1 },
                "actor": { "type": "string", "enum": ["user", "system", "partner"] },
                "action": { "type": "string" },
                "system_response": { "type": "string" }
              }
            }
          },
          "pain_points": {
            "type": "array",
            "items": { "type": "string" }
          },
          "success_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_ticket_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "statement", "priority", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "statement": { "type": "string" },
          "priority": { "type": "string", "enum": ["Must", "Should", "Could"] },
          "rationale": { "type": "string" },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "related_ticket_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_journey_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "edge_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["auth", "input_validation", "timeout", "offline", "permissions", "billing", "accessibility", "other"]
          },
          "linked_requirements": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "backlog": {
      "type": "object",
      "required": ["epics", "stories"],
      "properties": {
        "epics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "priority": { "type": "string", "enum": ["Must", "Should", "Could"] }
            }
          }
        },
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title", "acceptance_criteria", "priority"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "epic_id": { "type": "string" },
              "priority": { "type": "string", "enum": ["Must", "Should", "Could"] },
              "acceptance_criteria": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "linked_requirements": {
                "type": "array",
                "items": { "type": "string" }
              },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}

