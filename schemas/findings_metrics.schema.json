{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "findings_metrics.schema.json",
  "title": "Findings & Metrics",
  "description": "Output of Metrics & Analytics Agent: North Star, input metrics, guardrails, event taxonomy, integrity issues and recommendations",
  "type": "object",
  "required": [
    "bundle_id",
    "feature_area",
    "goals",
    "north_star_metric",
    "input_metrics",
    "guardrails",
    "event_taxonomy",
    "issues",
    "recommendations"
  ],
  "properties": {
    "bundle_id": { "type": "string" },
    "feature_area": { "type": "string", "description": "Primary feature/area derived from request and tickets" },
    "goals": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 5,
      "description": "2–3 short goals"
    },
    "north_star_metric": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "unit": { "type": "string" }
      }
    },
    "input_metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "unit": { "type": "string" }
        }
      },
      "minItems": 3,
      "maxItems": 6
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "unit": { "type": "string" }
        }
      },
      "minItems": 3,
      "maxItems": 5
    },
    "event_taxonomy": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_name", "description", "trigger"],
        "properties": {
          "event_name": { "type": "string" },
          "description": { "type": "string" },
          "trigger": { "type": "string" },
          "properties": { "type": "array", "items": { "type": "string" } },
          "required_properties": { "type": "array", "items": { "type": "string" } },
          "user_properties": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      },
      "minItems": 6,
      "maxItems": 15
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": { "type": "string", "enum": ["missing_baselines", "missing_segmentation", "tracking_gaps"] },
          "description": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
