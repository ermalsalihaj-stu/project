{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context_packet.schema.json",
  "title": "Product Context Packet",
  "description": "Output of Intake Agent - consolidated context consumed by all downstream agents",
  "type": "object",
  "required": ["bundle_id", "created_at", "tickets", "risk_tags"],
  "properties": {
    "bundle_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "request_summary": { "type": "string" },
    "tickets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "normalized": { "type": "object" }
        }
      }
    },
    "dedupe_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "representative_id": { "type": "string" },
          "duplicate_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "missing_info": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ticket_id": { "type": "string" },
          "field": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "risk_tags": {
      "type": "object",
      "description": "Risk hotspots: privacy, auth, billing, WCAG, etc.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "docs_index": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "summary": { "type": "string" }
        }
      }
    }
  }
}
