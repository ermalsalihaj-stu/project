{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metrics_snapshot.schema.json",
  "title": "Metrics Snapshot",
  "description": "Baseline metrics, funnel, guardrails, and segmentations",
  "type": "object",
  "required": ["time_window"],
  "properties": {
    "time_window": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}_to_[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Metric window (start_to_end)"
    },
    "north_star_candidate": { "type": "string", "description": "Proposed North Star metric" },
    "funnel": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "baseline": { "type": "number" },
          "current": { "type": "number" },
          "trend": { "type": "string" }
        }
      }
    },
    "product_health": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "baseline": { "type": "number" },
          "current": { "type": "number" },
          "trend": { "type": "string" }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "baseline": { "type": "number" },
          "current": { "type": "number" },
          "trend": { "type": "string" }
        }
      }
    },
    "segments": {
      "type": "object",
      "description": "Segment-level breakdowns",
      "additionalProperties": { "type": "object" }
    },
    "instrumentation_gaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
